{
    "imports": [
      "$import torch",
      "$from monai.networks.nets import UNet",
      "$from monai.losses import DiceLoss",
      "$from torch.optim import Adam"
    ],
  
    "device": "$torch.device('cuda' if torch.cuda.is_available() else 'cpu')",
  
    "network_def": {
      "_target_": "UNet",
      "spatial_dims": 3,
      "in_channels": 1,
      "out_channels": 1,
      "channels": [16, 32, 64],
      "strides": [2, 2],
      "num_res_units": 2
    },
  
    "network": "$@network_def.to(@device)",
  
    "loss": {
      "_target_": "DiceLoss",
      "sigmoid": true
    },
  
    "optimizer": {
      "_target_": "Adam",
      "params": "$@network.parameters()",
      "lr": 0.0001
    },
  
    "training_data": {
      "description": "Expected dataset format: 3D CBCT volumes and corresponding binary segmentation masks, preprocessed to [1, 64, 64, 32].",
      "image_key": "image",
      "label_key": "label"
    },
  
    "validation": {
      "metrics": [
        "Dice score",
        "Hausdorff distance",
        "Sensitivity",
        "Specificity"
      ]
    },
  
    "note": "This is a research-prototype training configuration. A real dataset and dataloader must be added before actual training."
  }