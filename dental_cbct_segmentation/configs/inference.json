{
    "imports": [
      "$import torch",
      "$import nibabel as nib",
      "$import numpy as np",
      "$from monai.networks.nets import UNet"
    ],
  
    "device": "$torch.device('cuda' if torch.cuda.is_available() else 'cpu')",
  
    "input_path": "$@bundle_root + '/testing_data/test_cbct.nii.gz'",
  
    "image": "$nib.load(@input_path).get_fdata().astype(np.float32)",
  
    "image_tensor": "$torch.tensor(@image).unsqueeze(0).unsqueeze(0).float().to(@device)",
  
    "network_def": {
      "_target_": "UNet",
      "spatial_dims": 3,
      "in_channels": 1,
      "out_channels": 1,
      "channels": [16, 32, 64],
      "strides": [2, 2],
      "num_res_units": 2
    },
  
    "network": "$@network_def.to(@device)",
  
    "prediction": "$@network(@image_tensor)",
  
    "run": "$print('Inference completed. Output shape:', @prediction.shape)"
  }