{
    "imports": [
      "$import os",
      "$import torch",
      "$import nibabel as nib",
      "$import numpy as np",
      "$from monai.networks.nets import UNet"
    ],
  
    "device": "$torch.device('cuda' if torch.cuda.is_available() else 'cpu')",
  
    "input_path": "$@bundle_root + '/testing_data/test_cbct.nii.gz'",
    "output_dir": "$@bundle_root + '/outputs'",
    "output_path": "$@output_dir + '/pred_mask.nii.gz'",
  
    "make_output_dir": "$os.makedirs(@output_dir, exist_ok=True)",
  
    "image_nii": "$nib.load(@input_path)",
    "image": "$@image_nii.get_fdata().astype(np.float32)",
  
    "image_tensor": "$torch.tensor(@image).unsqueeze(0).unsqueeze(0).float().to(@device)",
  
    "network_def": {
      "_target_": "UNet",
      "spatial_dims": 3,
      "in_channels": 1,
      "out_channels": 1,
      "channels": [16, 32, 64],
      "strides": [2, 2],
      "num_res_units": 2
    },
  
    "network": "$@network_def.to(@device)",
    "load_weights": "$@network.load_state_dict(torch.load(@bundle_root + '/models/model.pt', map_location=@device))",
    "set_eval": "$@network.eval()",
  
    "prediction": "$@network(@image_tensor)",
    "prediction_mask": "$(torch.sigmoid(@prediction) > 0.5).float().cpu().numpy()[0, 0]",
  
    "save_output": "$nib.save(nib.Nifti1Image(@prediction_mask.astype(np.float32), @image_nii.affine), @output_path)",
  
    "run": [
      "$@make_output_dir",
      "$@save_output",
      "$print('Inference completed. Saved output to:', @output_path)"
    ]
  }