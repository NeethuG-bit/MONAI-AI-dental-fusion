{
    "imports": [
      "$import torch",
      "$from monai.networks.nets import UNet"
    ],
  
    "device": "$torch.device('cuda' if torch.cuda.is_available() else 'cpu')",
  
    "network_def": {
      "_target_": "UNet",
      "spatial_dims": 3,
      "in_channels": 1,
      "out_channels": 1,
      "channels": [16, 32, 64],
      "strides": [2, 2],
      "num_res_units": 2
    },
  
    "network": "$@network_def.to(@device)",
  
    "run": "$print('Dental CBCT Segmentation bundle validation passed. Network initialized successfully.')"
  }